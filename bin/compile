#!/usr/bin/env bash
set -e

build="$1"
cache="$2"

CLAMAV_CACHE="${cache}/clamav"
CLAMAV_BUILD="${build}/.clamav"
DB_CACHE="${cache}/clamav-db"
DB_BUILD="${build}/.clamav-data"

mkdir -p "$CLAMAV_CACHE"
mkdir -p "$DB_CACHE"

echo "-----> Detecting latest ClamAV version from GitHub"

VERSION_FILE="${cache}/clamav-version"

LATEST_VERSION=$(curl -fsSL \
  -H "Accept: application/vnd.github+json" \
  -H "User-Agent: heroku-buildpack-clamav" \
  https://api.github.com/repos/Cisco-Talos/clamav/releases/latest \
  | grep '"tag_name":' \
  | sed -E 's/.*clamav-([^"]+)".*/\1/')

echo "Latest version: $LATEST_VERSION"

CACHED_VERSION=""
if [ -f "$VERSION_FILE" ]; then
  CACHED_VERSION=$(cat "$VERSION_FILE")
fi

if [ "$LATEST_VERSION" != "$CACHED_VERSION" ]; then
  echo "-----> Downloading ClamAV $LATEST_VERSION"

  cd /tmp

  DEB_URL="https://github.com/Cisco-Talos/clamav/releases/download/clamav-${LATEST_VERSION}/clamav-${LATEST_VERSION}.linux.x86_64.deb"

  curl -L "$DEB_URL" -o clamav.deb

  rm -rf "$CLAMAV_CACHE"/*
  mkdir -p "$CLAMAV_CACHE"

  dpkg -x clamav.deb "$CLAMAV_CACHE"

  rm -f clamav.deb

  echo "$LATEST_VERSION" > "$VERSION_FILE"
else
  echo "-----> Using cached ClamAV $CACHED_VERSION"
fi

# Make binaries available
export PATH="${CLAMAV_CACHE}/usr/bin:${CLAMAV_CACHE}/usr/sbin:$PATH"

echo "-----> Updating virus database"

freshclam \
  --datadir="$DB_CACHE" \
  --quiet

echo "-----> Copying ClamAV into slug"

rm -rf "$CLAMAV_BUILD"
cp -r "$CLAMAV_CACHE" "$CLAMAV_BUILD"

rm -rf "$DB_BUILD"
cp -r "$DB_CACHE" "$DB_BUILD"

echo "-----> ClamAV setup complete"